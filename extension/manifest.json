{
  "manifest_version": 3,
  "name": "SyncNews Audio に登録",
  "version": "1.0.0",
  "description": "開いているニュース記事をワンクリックで SyncNews Audio に登録します。",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://syncnews-convert-production.up.railway.app/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "この記事を SyncNews Audio に登録",
    "default_icon": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
  },
  "icons": { "16": "icon16.png", "48": "icon48.png", "128": "icon128.png" }
}
